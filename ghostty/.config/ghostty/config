# Theme
theme = catppuccin-mocha

# Font
font-family = JetBrainsMono Nerd Font
font-size = 13

# Window
window-padding-x = 8
window-padding-y = 4
window-decoration = true

# Cursor
cursor-style = bar
cursor-style-blink = true

# Shell integration
shell-integration = zsh
shell-integration-features = ssh-terminfo

# macOS specific
macos-option-as-alt = true
